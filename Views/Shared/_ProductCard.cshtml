@model PerfumeStore.Models.Product

<div class="card product-card h-100">
    <div class="position-relative">
        <a href="@Url.Action("Index", "Product", new { id = Model.ProductId })">
            @if (Model.ProductImages.Any())
            {
                var firstImage = Model.ProductImages.First();
                <img src="data:@firstImage.ImageMimeType;base64,@Convert.ToBase64String(firstImage.ImageData)" 
                     class="card-img-top" alt="@Model.ProductName" style="height: 250px; object-fit: cover;">
            }
            else
            {
                <img src="/images/ProductDetail/anh-1.webp" 
                     class="card-img-top" alt="@Model.ProductName" style="height: 250px; object-fit: cover;">
            }
        </a>
        
        <!-- Favorite button positioned on top right of image -->
        <div class="position-absolute" style="top: 10px; right: 10px;">
            @await Html.PartialAsync("_FavoriteButton", Model.ProductId)
        </div>
    </div>
    
    <div class="card-body d-flex flex-column">
        <a href="@Url.Action("Index", "Product", new { id = Model.ProductId })" class="text-decoration-none">
            <h6 class="card-title text-dark">@Model.ProductName</h6>
        </a>
        
        @if (Model.Brand != null)
        {
            <p class="text-muted small mb-2">@Model.Brand.BrandName</p>
        }
        
        @if (!string.IsNullOrEmpty(Model.Introduction))
        {
            <p class="card-text small text-muted">
                @(Model.Introduction.Length > 80 ? Model.Introduction.Substring(0, 80) + "..." : Model.Introduction)
            </p>
        }

        <div class="mt-auto">
            <div class="d-flex justify-content-between align-items-center mb-2">
                @if (Model.DiscountPrice.HasValue && Model.DiscountPrice > 0)
                {
                    <div>
                        <span class="text-decoration-line-through text-muted small">@Model.Price.ToString("N0") ₫</span>
                        <span class="text-danger fw-bold">@Model.DiscountPrice.Value.ToString("N0") ₫</span>
                    </div>
                }
                else
                {
                    <span class="text-primary fw-bold">@Model.Price.ToString("N0") ₫</span>
                }
            </div>

            <div class="d-flex gap-2">
                <a href="@Url.Action("Index", "Product", new { id = Model.ProductId })" 
                   class="btn btn-outline-primary btn-sm flex-fill">
                    <i class="bi bi-eye"></i> Xem chi tiết
                </a>
                <button class="btn btn-primary btn-sm" 
                        onclick="addToCartFromCard(@Model.ProductId, '@Model.ProductName')"
                        title="Thêm vào giỏ hàng">
                    <i class="bi bi-cart-plus"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
function addToCartFromCard(productId, productName) {
    // This function should integrate with your existing cart system
    // For now, just show an alert
    alert('Tính năng thêm vào giỏ hàng từ card sẽ được tích hợp với hệ thống giỏ hàng hiện có');
}
</script>