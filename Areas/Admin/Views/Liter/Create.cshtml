@model PerfumeStore.Areas.Admin.Models.Liter

@{
    ViewData["Title"] = "Thêm dung tích mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <div class="row justify-content-center mt-3">
        <div class="col-lg-8">
            <!-- Header -->
            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index" class="btn btn-outline-secondary me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h2 class="mb-0"><i class="bi bi-plus-circle text-primary"></i> Thêm dung tích mới</h2>
                    <p class="text-muted mb-0">Thêm dung tích nước hoa vào hệ thống</p>
                </div>
            </div>

            <!-- Form Card -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-droplet-half"></i> Thông tin dung tích</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row g-3">
                            <!-- Dung tích (ml) -->
                            <div class="col-md-6">
                                <label asp-for="LiterNumber" class="form-label fw-semibold">
                                    <i class="bi bi-droplet text-primary"></i> Dung tích (ml) <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <input asp-for="LiterNumber" class="form-control form-control-lg" 
                                           placeholder="Ví dụ: 50, 100, 200" type="number" min="1" required />
                                    <span class="input-group-text">ml</span>
                                </div>
                                <span asp-validation-for="LiterNumber" class="text-danger small"></span>
                                <small class="text-muted">Nhập số ml của dung tích nước hoa</small>
                            </div>

                            <!-- Giá -->
                            <div class="col-md-6">
                                <label asp-for="LiterPrice" class="form-label fw-semibold">
                                    <i class="bi bi-currency-dollar text-success"></i> Giá (VNĐ) <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text">₫</span>
                                    <input asp-for="LiterPrice" class="form-control form-control-lg price-input" 
                                           placeholder="1.580.000" type="text" required />
                                </div>
                                <span asp-validation-for="LiterPrice" class="text-danger small"></span>
                                <small class="text-muted">Giá bán của dung tích này</small>
                            </div>

                            <!-- Mô tả -->
                            <div class="col-12">
                                <label asp-for="LiterDescription" class="form-label fw-semibold">
                                    <i class="bi bi-card-text text-info"></i> Mô tả
                                </label>
                                <input asp-for="LiterDescription" class="form-control" 
                                       placeholder="Ví dụ: Xịt được khoảng 500 lần trong 12 tháng" />
                                <span asp-validation-for="LiterDescription" class="text-danger small"></span>
                                <small class="text-muted">Mô tả ngắn về dung tích (tùy chọn)</small>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                            <button type="submit" class="btn btn-primary px-5">
                                <i class="bi bi-save"></i> Lưu dung tích
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Info Card -->
            <div class="card border-0 shadow-sm mt-3 bg-light">
                <div class="card-body">
                    <h6 class="fw-semibold mb-2"><i class="bi bi-info-circle text-info"></i> Lưu ý:</h6>
                    <ul class="mb-0 small text-muted">
                        <li>Dung tích phải là số nguyên dương (ví dụ: 50, 100, 200)</li>
                        <li>Mỗi dung tích phải có giá riêng</li>
                        <li>Sau khi tạo, bạn có thể gán dung tích này cho các sản phẩm</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.querySelectorAll('.price-input').forEach(input => {
            // Format khi nhập
            input.addEventListener('input', function () {
                let value = this.value.replace(/\D/g, "");
                if (value) {
                    value = parseInt(value).toLocaleString('vi-VN');
                    this.value = value;
                }
            });

            // Xóa format trước khi submit
            input.form.addEventListener('submit', function () {
                input.value = input.value.replace(/\./g, "").replace(/,/g, "");
            });
        });
    </script>
}
